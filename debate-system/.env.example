# API Configuration
API_KEY=your_api_key_here
API_BASE=https://openrouter.ai/api/v1

# Default Models
DEFAULT_HOMOGENEOUS_MODEL=meta-llama/llama-3.3-70b-instruct
DEFAULT_INDIVIDUAL_MODEL=qwen/qwen-2.5-72b-instruct

# Heterogeneous Models
HETEROGENEOUS_MODERATOR_MODEL=nousresearch/hermes-3-llama-3.1-405b
HETEROGENEOUS_DLB_MODEL=meta-llama/llama-3.3-70b-instruct
HETEROGENEOUS_PNM_MODEL=qwen/qwen-2.5-72b-instruct

# RAG Configuration
RAG_DATA_PATH=/path/to/your/dataset_preprocesado_rag/
RAG_MODEL_PATH=/path/to/your/embeddings_model/multi-qa-MiniLM-L6-cos-v1

# FAISS Configuration
DEFAULT_K=2
EMBEDDING_DEVICE=cpu

# Rate Limiting
SLEEP_BASE=12
SLEEP_JITTER=4
MAX_RETRIES=2
RETRY_BASE_DELAY=15

# Debate Configuration
MAX_ROUNDS=6
MAX_MESSAGES=40
MAX_TOKENS_PER_RESPONSE=500

# Output Configuration
DEFAULT_OUTPUT_DIR=./outputs
DEFAULT_DECISION_DIR=./decisions